{
  "appId": "cl.cubo.control.terminal",
  "productName": "CUBO Control Terminal",
  "directories": {
    "output": "dist"
  },
  "files": [
    "dist/renderer/**/*",
    "electron/**/*",
    "package.json"
  ],
  "extraMetadata": {
    "main": "electron/main.js"
  },
  "win": {
    "signAndEditExecutable": false,
    "target": [
      "dir",
      "portable"
    ],
    "artifactName": "CUBO-Control-Terminal-${version}-${arch}.${ext}"
  }
}
